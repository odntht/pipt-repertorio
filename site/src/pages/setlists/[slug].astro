---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadAllSetlists } from '@/lib/setlists/load';
import { loadAllSongs } from '@/lib/songs/load';

export async function getStaticPaths() {
  const setlists = loadAllSetlists();
  return setlists.map((s) => ({ params: { slug: s.slug }, props: { setlist: s } }));
}

const { setlist } = Astro.props;
const base = import.meta.env.BASE_URL;

const songs = loadAllSongs();
// Chave completa `slug.qualifier?.tom` casa com o arquivo exato.
const byFullKey = new Map(
  songs.map((s) => {
    const key = s.qualifiers.length > 0
      ? `${s.slug}.${s.qualifiers.join('.')}.${s.tom}`
      : `${s.slug}.${s.tom}`;
    return [key, s];
  }),
);
const bySlug = new Map<string, typeof songs[number]>();
for (const s of songs) if (!bySlug.has(s.slug)) bySlug.set(s.slug, s);

function formatDate(iso: string): string {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
}

interface ResolvedItem {
  slug: string;
  qualifier: string;
  tom: string;
  notes?: string;
  title: string;
  hinarioNum?: string;
  artist?: string;
  hasFile: boolean;
}
const resolved: ResolvedItem[] = setlist.songs.map((item) => {
  const qualifier = (item.qualifier ?? '').trim();
  const key = qualifier
    ? `${item.slug}.${qualifier}.${item.tom.toLowerCase()}`
    : `${item.slug}.${item.tom.toLowerCase()}`;
  const exact = byFullKey.get(key);
  const fallback = bySlug.get(item.slug);
  const meta = exact?.song.metadata ?? fallback?.song.metadata;
  return {
    slug: item.slug,
    qualifier,
    tom: item.tom,
    notes: item.notes,
    title: meta?.title ?? item.slug,
    hinarioNum: meta?.hinarioNum,
    artist: meta?.artist,
    hasFile: !!exact,
  };
});
---

<BaseLayout title={setlist.event}>
  <header class="mb-4">
    <h1 class="text-2xl font-bold">{setlist.event}</h1>
    <p class="text-sm text-gray-600 dark:text-gray-400">
      {formatDate(setlist.date)} · {setlist.songs.length} música{setlist.songs.length === 1 ? '' : 's'}
    </p>
    <a href={`${base}setlists/`} class="text-sm text-mmu-green hover:underline no-print">
      ← Todas as setlists
    </a>
  </header>

  <ol class="space-y-3">
    {resolved.map((item, i) => (
      <li class="border-b pb-3">
        <div class="flex items-baseline gap-3">
          <span class="text-2xl font-bold text-gray-400 tabular-nums">
            {String(i + 1).padStart(2, '0')}
          </span>
          <div class="flex-1">
            <a
              href={item.hasFile ? `${base}musicas/${item.slug}/${item.tom.toLowerCase()}` : '#'}
              class={item.hasFile ? 'font-semibold uppercase hover:text-mmu-green' : 'font-semibold uppercase opacity-50'}
            >
              {item.hinarioNum && `HINO ${item.hinarioNum} – `}
              {item.title}
            </a>
            <div class="text-sm text-gray-500 flex flex-wrap gap-2">
              <span>Tom: <strong>{item.tom.toUpperCase()}</strong></span>
              {item.artist && <span>· {item.artist}</span>}
              {!item.hasFile && (
                <span class="text-red-600 dark:text-red-400">
                  ⚠ tom não encontrado
                </span>
              )}
            </div>
            {item.notes && (
              <p class="text-sm italic text-gray-600 dark:text-gray-400 mt-1">
                {item.notes}
              </p>
            )}
          </div>
        </div>
      </li>
    ))}
  </ol>

  <div class="mt-6 flex flex-wrap gap-2 no-print">
    <button
      id="edit-btn"
      type="button"
      class="text-sm border rounded px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-800"
    >
      Editar
    </button>
    <button
      id="delete-btn"
      type="button"
      class="text-sm text-red-600 border border-red-300 dark:border-red-700 rounded px-3 py-2 hover:bg-red-50 dark:hover:bg-red-950"
    >
      Deletar
    </button>
  </div>
  <script is:inline define:vars={{ setlist, base }}>
    document.getElementById('edit-btn')?.addEventListener('click', () => {
      sessionStorage.setItem('setlist.edit', JSON.stringify(setlist));
      window.location.href = `${base}setlists/novo/`;
    });
    document.getElementById('delete-btn')?.addEventListener('click', () => {
      const ok = confirm(
        `Deletar a setlist "${setlist.event}" (${setlist.date})?\n\n` +
        `Vamos abrir o GitHub pra você confirmar a exclusão do arquivo ` +
        `data/setlists/${setlist.filename}.`,
      );
      if (!ok) return;
      window.open(
        `https://github.com/odntht/pipt-repertorio/delete/main/data/setlists/${setlist.filename}`,
        '_blank',
        'noopener,noreferrer',
      );
    });
  </script>
</BaseLayout>
