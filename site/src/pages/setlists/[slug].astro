---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadAllSetlists } from '@/lib/setlists/load';
import { loadAllSongs } from '@/lib/songs/load';
import { tomOrder } from '@/lib/setlists/tom-order';

export async function getStaticPaths() {
  const setlists = loadAllSetlists();
  return setlists.map((s) => ({ params: { slug: s.slug }, props: { setlist: s } }));
}

const { setlist } = Astro.props;
const base = import.meta.env.BASE_URL;

// Reconstrói o YAML da setlist com um estado alternativo de `hidden`.
// Passado pro botão inline; evita duplicar a lógica de build no JS.
function buildYamlForSetlist(
  sl: typeof setlist,
  hidden: boolean,
): string {
  const lines: string[] = [];
  lines.push(`event: "${sl.event.replace(/"/g, '\\"')}"`);
  lines.push(`date: ${sl.date}`);
  if (hidden) lines.push('hidden: true');
  lines.push('songs:');
  for (const s of sl.songs) {
    lines.push(`  - slug: ${s.slug}`);
    if (s.qualifier) lines.push(`    qualifier: ${s.qualifier}`);
    lines.push(`    tom: ${s.tom.toLowerCase()}`);
    if (s.moments && s.moments.length > 0) {
      lines.push(`    moments: [${s.moments.join(', ')}]`);
    }
    if (s.notes) lines.push(`    notes: "${s.notes.replace(/"/g, '\\"')}"`);
  }
  return lines.join('\n') + '\n';
}

const yamlHidden = buildYamlForSetlist(setlist, true);
const yamlVisible = buildYamlForSetlist(setlist, false);

const songs = loadAllSongs();
// Chave completa `slug.qualifier?.tom` casa com o arquivo exato.
const byFullKey = new Map(
  songs.map((s) => {
    const key = s.qualifiers.length > 0
      ? `${s.slug}.${s.qualifiers.join('.')}.${s.tom}`
      : `${s.slug}.${s.tom}`;
    return [key, s];
  }),
);
const bySlug = new Map<string, typeof songs[number]>();
for (const s of songs) if (!bySlug.has(s.slug)) bySlug.set(s.slug, s);

function formatDate(iso: string): string {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
}

interface ResolvedItem {
  slug: string;
  qualifier: string;
  tom: string;
  notes?: string;
  moments?: string[];
  title: string;
  hinarioNum?: string;
  artist?: string;
  hasFile: boolean;
}
const MOMENT_LABELS: Record<string, string> = {
  manha: 'Manhã',
  noite: 'Noite',
  ceia: 'Ceia',
  preludio: 'Prelúdio',
  posludio: 'Poslúdio',
};
function tomUrlKey(qualifier: string, tom: string): string {
  return qualifier ? `${qualifier}.${tom.toLowerCase()}` : tom.toLowerCase();
}
// Dedup toms dentro de um grupo e ordena cromaticamente (C → B).
// Preserva o item completo (link/notes) da primeira ocorrência de cada tom.
function uniqueByTom<T extends { tom: string }>(items: T[]): T[] {
  const seen = new Set<string>();
  const out: T[] = [];
  for (const it of items) {
    const t = it.tom.toLowerCase();
    if (seen.has(t)) continue;
    seen.add(t);
    out.push(it);
  }
  return out.sort((a, b) => tomOrder(a.tom) - tomOrder(b.tom));
}
// Agrupa entradas consecutivas com o mesmo slug — mesma música, versões
// diferentes viram um item só com múltiplos tons/qualifiers.
function groupBySlug<T extends { slug: string }>(items: T[]): T[][] {
  const groups: T[][] = [];
  for (const it of items) {
    const last = groups[groups.length - 1];
    if (last && last[0].slug === it.slug) last.push(it);
    else groups.push([it]);
  }
  return groups;
}
const resolved: ResolvedItem[] = setlist.songs.map((item) => {
  const qualifier = (item.qualifier ?? '').trim();
  const key = qualifier
    ? `${item.slug}.${qualifier}.${item.tom.toLowerCase()}`
    : `${item.slug}.${item.tom.toLowerCase()}`;
  const exact = byFullKey.get(key);
  const fallback = bySlug.get(item.slug);
  const meta = exact?.song.metadata ?? fallback?.song.metadata;
  return {
    slug: item.slug,
    qualifier,
    tom: item.tom,
    notes: item.notes,
    moments: item.moments,
    title: meta?.title ?? item.slug,
    hinarioNum: meta?.hinarioNum,
    artist: meta?.artist,
    hasFile: !!exact,
  };
});
---

<BaseLayout title={setlist.event}>
  <header class="mb-4">
    <div class="flex flex-wrap items-baseline gap-2">
      <h1 class="text-2xl font-bold">{setlist.event}</h1>
      {setlist.hidden && (
        <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-gray-400 text-white no-print">
          Oculta
        </span>
      )}
    </div>
    <p class="text-sm text-gray-600 dark:text-gray-400">
      {formatDate(setlist.date)} · {setlist.songs.length} música{setlist.songs.length === 1 ? '' : 's'}
    </p>
    <a href={`${base}setlists/`} class="text-sm text-mmu-green hover:underline no-print">
      ← Todas as setlists
    </a>
    <div class="mt-3 flex flex-wrap gap-2 no-print">
      <a
        href={`${base}setlists/${setlist.slug}/imprimir/`}
        class="text-sm border rounded px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-800"
      >
        Imprimir / PDF
      </a>
      <a
        href={`${base}setlists/${setlist.slug}/imprimir/?letras=1`}
        class="text-sm border rounded px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-800"
      >
        Imprimir letras
      </a>
      <button
        id="edit-btn"
        type="button"
        class="text-sm border rounded px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-800"
      >
        Editar
      </button>
      <button
        id="hide-btn"
        type="button"
        class="text-sm border rounded px-3 py-2 hover:bg-gray-100 dark:hover:bg-gray-800"
      >
        {setlist.hidden ? 'Mostrar novamente' : 'Ocultar'}
      </button>
      <p id="hide-hint" class="w-full text-sm text-mmu-green mt-2 hidden"></p>
    </div>
  </header>

  <ol class="space-y-3">
    {groupBySlug(resolved).map((group, i) => {
      const head = group[0];
      const uniqTomEntries = uniqueByTom(group);
      const showTomHeaders = uniqTomEntries.length > 1;
      return (
        <li class="border-b pb-3">
          <div class="flex items-baseline gap-3">
            <span class="text-2xl font-bold text-gray-400 tabular-nums">
              {String(i + 1).padStart(2, '0')}
            </span>
            <div class="flex-1">
              <div class="font-semibold uppercase">
                {head.hinarioNum && `HINO ${head.hinarioNum} – `}
                {head.title}
                {' – '}
                {uniqTomEntries.map((item, j) => (
                  <>
                    {j > 0 && ', '}
                    <a
                      href={item.hasFile ? `${base}musicas/${item.slug}/${tomUrlKey(item.qualifier, item.tom)}` : '#'}
                      class={item.hasFile ? 'hover:text-mmu-green underline' : 'opacity-50'}
                    >
                      {item.tom.toUpperCase()}
                    </a>
                  </>
                ))}
              </div>
              {head.artist && (
                <div class="text-sm text-gray-500">{head.artist}</div>
              )}
              {uniqTomEntries.map((item) => (
                <>
                  {(item.moments && item.moments.length > 0) || item.notes || !item.hasFile ? (
                    <div class="mt-1 ml-1 border-l-2 border-gray-200 dark:border-gray-700 pl-2">
                      {showTomHeaders && (
                        <div class="text-xs text-gray-500">
                          {item.tom.toUpperCase()}
                        </div>
                      )}
                      {item.moments && item.moments.length > 0 && (
                        <div class="flex flex-wrap gap-1 mt-1">
                          {item.moments.map((m) => (
                            <span class="inline-block px-2 py-0.5 rounded text-xs bg-mmu-green/15 text-mmu-green">
                              {MOMENT_LABELS[m] ?? m}
                            </span>
                          ))}
                        </div>
                      )}
                      {item.notes && (
                        <p class="text-sm italic text-gray-600 dark:text-gray-400 mt-1">
                          {item.notes}
                        </p>
                      )}
                      {!item.hasFile && (
                        <span class="text-xs text-red-600 dark:text-red-400">
                          ⚠ tom não encontrado
                        </span>
                      )}
                    </div>
                  ) : null}
                </>
              ))}
            </div>
          </div>
        </li>
      );
    })}
  </ol>

  <script
    is:inline
    define:vars={{ setlist, base, yamlHidden, yamlVisible }}
  >
    document.getElementById('edit-btn')?.addEventListener('click', () => {
      sessionStorage.setItem('setlist.edit', JSON.stringify(setlist));
      window.location.href = `${base}setlists/novo/`;
    });
    document.getElementById('hide-btn')?.addEventListener('click', async () => {
      const isHidden = setlist.hidden;
      const targetYaml = isHidden ? yamlVisible : yamlHidden;
      const verb = isHidden ? 'mostrar novamente' : 'ocultar';
      const ok = confirm(
        `${verb.charAt(0).toUpperCase() + verb.slice(1)} a setlist "${setlist.event}"?\n\n` +
        `Vamos copiar o YAML atualizado pro clipboard e abrir o GitHub — ` +
        `você cola por cima do conteúdo do arquivo pra confirmar.`,
      );
      if (!ok) return;
      const hint = document.getElementById('hide-hint');
      try {
        await navigator.clipboard.writeText(targetYaml);
        if (hint) {
          hint.textContent =
            'YAML copiado. Na aba do GitHub que abriu, faça Cmd+A pra selecionar tudo e Cmd+V pra colar por cima.';
          hint.classList.remove('hidden');
        }
      } catch {
        if (hint) {
          hint.textContent =
            'Clipboard indisponível — copie o YAML manualmente do detalhe.';
          hint.classList.remove('hidden');
        }
      }
      window.open(
        `https://github.com/odntht/pipt-repertorio/edit/main/data/setlists/${setlist.filename}`,
        '_blank',
        'noopener,noreferrer',
      );
    });
  </script>
</BaseLayout>
