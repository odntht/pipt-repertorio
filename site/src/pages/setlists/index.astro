---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadAllSetlists } from '@/lib/setlists/load';

const base = import.meta.env.BASE_URL;
const setlists = loadAllSetlists();
const visible = setlists.filter((s) => !s.hidden);
const hidden = setlists.filter((s) => s.hidden);

function formatDate(iso: string): string {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
}
---

<BaseLayout title="Setlists">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold">Setlists</h1>
    <a
      href={`${base}setlists/novo/`}
      class="bg-mmu-green text-white px-3 py-2 rounded text-sm font-semibold hover:opacity-90"
    >
      + Nova setlist
    </a>
  </div>

  {visible.length === 0 ? (
    <p class="text-sm text-gray-500 italic">
      Nenhuma setlist ativa. Clique em <em>+ Nova setlist</em> pra criar.
    </p>
  ) : (
    <ul class="space-y-2">
      {visible.map((s) => (
        <li class="border-b pb-2">
          <a
            href={`${base}setlists/${s.slug}/`}
            class="flex flex-wrap items-center gap-2 hover:text-mmu-green"
          >
            <span class="font-semibold">{s.event}</span>
            <span class="text-sm text-gray-500">{formatDate(s.date)}</span>
            <span class="ml-auto text-sm text-gray-500">
              {s.songs.length} música{s.songs.length === 1 ? '' : 's'}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}

  {hidden.length > 0 && (
    <div class="mt-8">
      <button
        id="toggle-hidden"
        type="button"
        class="text-sm text-gray-500 hover:text-mmu-green hover:underline"
      >
        Mostrar setlists ocultas ({hidden.length})
      </button>
      <ul id="hidden-list" class="mt-2 space-y-2 hidden">
        {hidden.map((s) => (
          <li class="border-b pb-2 opacity-60">
            <a
              href={`${base}setlists/${s.slug}/`}
              class="flex flex-wrap items-center gap-2 hover:text-mmu-green"
            >
              <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-gray-400 text-white">
                Oculta
              </span>
              <span class="font-semibold">{s.event}</span>
              <span class="text-sm text-gray-500">{formatDate(s.date)}</span>
              <span class="ml-auto text-sm text-gray-500">
                {s.songs.length} música{s.songs.length === 1 ? '' : 's'}
              </span>
            </a>
          </li>
        ))}
      </ul>
      <script is:inline>
        (function () {
          const btn = document.getElementById('toggle-hidden');
          const list = document.getElementById('hidden-list');
          if (!btn || !list) return;
          btn.addEventListener('click', () => {
            const showing = !list.classList.contains('hidden');
            if (showing) {
              list.classList.add('hidden');
              btn.textContent = btn.textContent.replace(
                /^Ocultar/,
                'Mostrar',
              );
            } else {
              list.classList.remove('hidden');
              btn.textContent = btn.textContent.replace(
                /^Mostrar/,
                'Ocultar',
              );
            }
          });
        })();
      </script>
    </div>
  )}
</BaseLayout>
