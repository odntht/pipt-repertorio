---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadAllSetlists } from '@/lib/setlists/load';

const base = import.meta.env.BASE_URL;
const setlists = loadAllSetlists();
const visible = setlists.filter((s) => !s.hidden);
const hidden = setlists.filter((s) => s.hidden);

function formatDate(iso: string): string {
  if (!/^\d{4}-\d{2}-\d{2}$/.test(iso)) return iso;
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y}`;
}
---

<BaseLayout title="Setlists">
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-2xl font-bold">Setlists</h1>
    <a
      href={`${base}setlists/novo/`}
      class="bg-mmu-green text-white px-3 py-2 rounded text-sm font-semibold hover:opacity-90"
    >
      + Nova setlist
    </a>
  </div>

  {visible.length === 0 ? (
    <p class="text-sm text-gray-500 italic">
      Nenhuma setlist ativa. Clique em <em>+ Nova setlist</em> pra criar.
    </p>
  ) : (
    <ul class="space-y-2">
      {visible.map((s) => (
        <li class="border-b pb-2">
          <a
            href={`${base}setlists/${s.slug}/`}
            class="flex flex-wrap items-center gap-2 hover:text-mmu-green"
          >
            <span class="font-semibold">{s.event}</span>
            <span class="text-sm text-gray-500">{formatDate(s.date)}</span>
            <span class="ml-auto text-sm text-gray-500">
              {s.songs.length} música{s.songs.length === 1 ? '' : 's'}
            </span>
          </a>
        </li>
      ))}
    </ul>
  )}

  <div class="mt-8">
    <h2 class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-1">
      Suas setlists <span class="text-xs text-gray-400">(neste navegador)</span>
    </h2>
    <ul id="local-setlists" class="space-y-2">
      <li class="text-sm italic text-gray-500">
        Carregando setlists locais…
      </li>
    </ul>
  </div>
  <script is:inline define:vars={{ base }}>
    (function () {
      const key = 'pipt.setlists';
      const listEl = document.getElementById('local-setlists');
      if (!listEl) return;
      let raw;
      try {
        raw = localStorage.getItem(key);
      } catch {
        listEl.innerHTML =
          '<li class="text-sm italic text-gray-500">Armazenamento local indisponível.</li>';
        return;
      }
      let entries = [];
      if (raw) {
        try {
          entries = JSON.parse(raw) || [];
        } catch {
          entries = [];
        }
      }
      if (!Array.isArray(entries) || entries.length === 0) {
        listEl.innerHTML =
          '<li class="text-sm italic text-gray-500">Nenhuma setlist salva neste navegador. Crie uma em <em>+ Nova setlist</em>.</li>';
        return;
      }
      entries.sort((a, b) => (b.date || '').localeCompare(a.date || ''));
      listEl.innerHTML = entries
        .map((s) => {
          const label = String(s.event || '(sem título)');
          const date = String(s.date || '');
          const n = Array.isArray(s.songs) ? s.songs.length : 0;
          const url = `${base}setlists/local/?id=${encodeURIComponent(s.id)}`;
          const dateFmt = /^\d{4}-\d{2}-\d{2}$/.test(date)
            ? date.split('-').reverse().join('/')
            : date;
          return `<li class="border-b pb-2">
            <a href="${url}" class="flex flex-wrap items-center gap-2 hover:text-mmu-green">
              <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-mmu-green text-white">Local</span>
              <span class="font-semibold">${label.replace(/[<>]/g, '')}</span>
              <span class="text-sm text-gray-500">${dateFmt}</span>
              <span class="ml-auto text-sm text-gray-500">${n} música${n === 1 ? '' : 's'}</span>
            </a>
          </li>`;
        })
        .join('');
    })();
  </script>

  {hidden.length > 0 && (
    <div class="mt-8">
      <button
        id="toggle-hidden"
        type="button"
        class="text-sm text-gray-500 hover:text-mmu-green hover:underline"
      >
        Mostrar setlists ocultas ({hidden.length})
      </button>
      <ul id="hidden-list" class="mt-2 space-y-2 hidden">
        {hidden.map((s) => (
          <li class="border-b pb-2 opacity-60">
            <a
              href={`${base}setlists/${s.slug}/`}
              class="flex flex-wrap items-center gap-2 hover:text-mmu-green"
            >
              <span class="inline-block px-2 py-0.5 rounded text-xs font-semibold bg-gray-400 text-white">
                Oculta
              </span>
              <span class="font-semibold">{s.event}</span>
              <span class="text-sm text-gray-500">{formatDate(s.date)}</span>
              <span class="ml-auto text-sm text-gray-500">
                {s.songs.length} música{s.songs.length === 1 ? '' : 's'}
              </span>
            </a>
          </li>
        ))}
      </ul>
      <script is:inline>
        (function () {
          const btn = document.getElementById('toggle-hidden');
          const list = document.getElementById('hidden-list');
          if (!btn || !list) return;
          btn.addEventListener('click', () => {
            const showing = !list.classList.contains('hidden');
            if (showing) {
              list.classList.add('hidden');
              btn.textContent = btn.textContent.replace(
                /^Ocultar/,
                'Mostrar',
              );
            } else {
              list.classList.remove('hidden');
              btn.textContent = btn.textContent.replace(
                /^Mostrar/,
                'Ocultar',
              );
            }
          });
        })();
      </script>
    </div>
  )}
</BaseLayout>
