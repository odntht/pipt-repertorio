---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionBadge from '@/components/SectionBadge.astro';
import SongViewer from '@/components/SongViewer';
import { loadAllSongs } from '@/lib/songs/load';

export async function getStaticPaths() {
  const songs = loadAllSongs();
  // URL segment do tom inclui qualifier quando existe — evita colisão
  // entre `slug.g.pro` e `slug.v2.g.pro` no mesmo path.
  const tomKeyOf = (entry: (typeof songs)[number]) =>
    entry.qualifiers.length > 0
      ? `${entry.qualifiers.join('.')}.${entry.tom}`
      : entry.tom;
  return songs.map((entry) => ({
    params: { slug: entry.slug, tom: tomKeyOf(entry) },
    props: {
      song: entry.song,
      qualifiers: entry.qualifiers,
      availableToms: songs
        .filter((s) => s.slug === entry.slug)
        .map((s) => ({
          key: tomKeyOf(s),
          tom: s.tom,
          qualifier: s.qualifiers.join('.'),
        })),
    },
  }));
}

function prettyQualifier(q: string): string {
  if (q === 'v1') return '';
  const mV = q.match(/^v(\d+)$/);
  if (mV) return `v${mV[1]}`;
  const mNamed = q.match(/^versao-(.+)$/);
  if (mNamed) {
    return `v. ${mNamed[1]
      .split('-')
      .map((w) => w.charAt(0).toUpperCase() + w.slice(1))
      .join(' ')}`;
  }
  const mA = q.match(/^arranjo-(\d+)$/);
  if (mA) return `arranjo ${mA[1]}`;
  // 'versao' bare permanece rotulado — colide com variante sem qualifier.
  if (q === 'versao') return 'versão';
  return q.replace(/-/g, ' ');
}

const { song, availableToms, qualifiers } = Astro.props;
const { slug } = Astro.params;
const base = import.meta.env.BASE_URL;

const parenBits = [
  song.metadata.artist,
  ...qualifiers.map(prettyQualifier),
].filter(Boolean);
const paren = parenBits.length ? ` (${parenBits.join(', ')})` : '';
const hinoPrefix = song.metadata.hinarioNum ? `HINO ${song.metadata.hinarioNum} – ` : '';
const titleBase = `${hinoPrefix}${song.metadata.title}${paren}`;
const browserTitle = `${titleBase} – ${song.metadata.key}`;
---

<BaseLayout title={browserTitle}>
  <article>
    <div class="mb-4 no-print flex flex-wrap items-center gap-2 text-sm text-gray-600 dark:text-gray-400">
      <SectionBadge section={song.metadata.section} />
      {song.metadata.tags.length > 0 && (
        <>
          <span>·</span>
          <span>{song.metadata.tags.join(', ')}</span>
        </>
      )}
      {song.metadata.youtube && (
        <a
          href={song.metadata.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="text-mmu-green hover:underline"
        >
          ▶ YouTube (referência) ↗
        </a>
      )}
    </div>

    <SongViewer
      client:load
      song={song}
      availableToms={availableToms}
      slug={slug!}
      base={base}
      titleBase={titleBase}
    />

    <div class="mt-4 no-print">
      <button
        id="new-version-btn"
        type="button"
        class="text-sm text-mmu-green hover:underline"
      >
        + Criar nova versão dessa música
      </button>
    </div>
    <script is:inline define:vars={{ raw: song.raw, slug, tom: Astro.params.tom, base }}>
      document.getElementById('new-version-btn')?.addEventListener('click', () => {
        sessionStorage.setItem(
          'newVersion.source',
          JSON.stringify({ raw, slug, tom }),
        );
        window.location.href = `${base}musicas/nova/`;
      });
    </script>

    {song.metadata.arrangements.length > 0 && (
      <section class="mt-8 border-t pt-4 no-print">
        <h2 class="text-lg font-semibold mb-2">🎧 Gravações do ministério</h2>
        <ul class="space-y-1">
          {song.metadata.arrangements.map((a, i) => (
            <li>
              <a
                href={a.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-mmu-green hover:underline"
              >
                {a.label ?? `Gravação ${i + 1}`} ↗
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
