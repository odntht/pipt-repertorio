---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionBadge from '@/components/SectionBadge.astro';
import SongViewer from '@/components/SongViewer';
import { loadAllSongs } from '@/lib/songs/load';

export async function getStaticPaths() {
  const songs = loadAllSongs();
  return songs.map((entry) => ({
    params: { slug: entry.slug, tom: entry.tom },
    props: {
      song: entry.song,
      qualifiers: entry.qualifiers,
      availableToms: songs
        .filter((s) => s.slug === entry.slug)
        .map((s) => s.tom),
    },
  }));
}

function prettyQualifier(q: string): string {
  const m1 = q.match(/^v(\d+)$/);
  if (m1) return `versão ${m1[1]}`;
  const m2 = q.match(/^arranjo-(\d+)$/);
  if (m2) return `arranjo ${m2[1]}`;
  if (q === 'versao') return 'versão';
  return q.replace(/-/g, ' ');
}

const { song, availableToms, qualifiers } = Astro.props;
const { slug, tom } = Astro.params;
const base = import.meta.env.BASE_URL;

const printParenBits = [
  song.metadata.artist,
  ...qualifiers.map(prettyQualifier),
].filter(Boolean);
const printParen = printParenBits.length ? ` (${printParenBits.join(', ')})` : '';
const printPrefix = song.metadata.hinarioNum ? `HINO ${song.metadata.hinarioNum} – ` : '';
const printHeader = `${printPrefix}${song.metadata.title.toUpperCase()}${printParen} – ${song.metadata.key}`;
---

<BaseLayout title={song.metadata.title}>
  <article>
    <header class="mb-4 no-print">
      <h1 class="text-2xl font-bold">{song.metadata.title}</h1>
      <div class="flex flex-wrap items-center gap-2 text-sm text-gray-600 dark:text-gray-400 mt-1">
        {song.metadata.artist && <span>{song.metadata.artist}</span>}
        {song.metadata.artist && <span>·</span>}
        <SectionBadge section={song.metadata.section} />
        {song.metadata.tags.length > 0 && (
          <>
            <span>·</span>
            <span>{song.metadata.tags.join(', ')}</span>
          </>
        )}
      </div>
      {song.metadata.youtube && (
        <a
          href={song.metadata.youtube}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block mt-2 text-sm text-mmu-green hover:underline no-print"
        >
          ▶ YouTube (referência) ↗
        </a>
      )}
    </header>

    <h1 class="print-only text-xl font-bold mb-4" style="font-family: monospace;">
      {printHeader}
    </h1>

    <SongViewer
      client:load
      song={song}
      availableToms={availableToms}
      slug={slug!}
      base={base}
    />

    <div class="mt-4 no-print">
      <button
        id="new-version-btn"
        type="button"
        class="text-sm text-mmu-green hover:underline"
      >
        + Criar nova versão dessa música
      </button>
    </div>
    <script is:inline define:vars={{ raw: song.raw, slug, tom, base }}>
      document.getElementById('new-version-btn')?.addEventListener('click', () => {
        sessionStorage.setItem(
          'newVersion.source',
          JSON.stringify({ raw, slug, tom }),
        );
        window.location.href = `${base}musicas/nova/`;
      });
    </script>

    {song.metadata.arrangements.length > 0 && (
      <section class="mt-8 border-t pt-4 no-print">
        <h2 class="text-lg font-semibold mb-2">🎧 Gravações do ministério</h2>
        <ul class="space-y-1">
          {song.metadata.arrangements.map((a, i) => (
            <li>
              <a
                href={a.url}
                target="_blank"
                rel="noopener noreferrer"
                class="text-mmu-green hover:underline"
              >
                {a.label ?? `Gravação ${i + 1}`} ↗
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>
