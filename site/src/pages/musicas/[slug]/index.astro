---
import { loadAllSongs } from '@/lib/songs/load';

export async function getStaticPaths() {
  const songs = loadAllSongs();
  const bySlug = new Map<string, string>();
  // Preferência de default: primeiro sem qualifier, senão a primeira variante.
  const sorted = [...songs].sort(
    (a, b) => a.qualifiers.length - b.qualifiers.length,
  );
  for (const s of sorted) {
    if (bySlug.has(s.slug)) continue;
    const tomKey = s.qualifiers.length > 0
      ? `${s.qualifiers.join('.')}.${s.tom}`
      : s.tom;
    bySlug.set(s.slug, tomKey);
  }
  return Array.from(bySlug.entries()).map(([slug, tomKey]) => ({
    params: { slug },
    props: { defaultTomKey: tomKey },
  }));
}

return Astro.redirect(
  `${import.meta.env.BASE_URL}musicas/${Astro.params.slug}/${Astro.props.defaultTomKey}`,
);
---
