---
import BaseLayout from '@/layouts/BaseLayout.astro';
import MusicasList from '@/components/MusicasList';
import { loadAllSongs } from '@/lib/songs/load';

const base = import.meta.env.BASE_URL;

const songs = loadAllSongs();

// Extrai só a letra pra busca client-side: sem metadata, sem [chord]
// markers, sem section-comments. Uma linha por linha de letra.
function extractSearchableLyrics(raw: string): string {
  const kept: string[] = [];
  for (const line of raw.split('\n')) {
    if (/^\s*\{/.test(line)) continue;
    const stripped = line.replace(/\[[^\]]+\]/g, '');
    if (stripped.trim() === '') continue;
    kept.push(stripped);
  }
  return kept.join('\n');
}

// Tom-key canônico da variante — combina com a rota `[tom].astro`.
function tomKeyOf(s: (typeof songs)[number]): string {
  return s.qualifiers.length > 0
    ? `${s.qualifiers.join('.')}.${s.tom}`
    : s.tom;
}

// Consolida versões (múltiplos toms) numa entrada por slug.
// `defaultTomKey` é o tom-alvo do link da lista — preferindo variantes
// sem qualifier (mesma regra do antigo redirect em [slug]/index.astro,
// que agora existe só como safety net p/ URLs digitadas à mão).
const bySlug = new Map<
  string,
  {
    slug: string;
    title: string;
    artist?: string;
    section: 'congregacional' | 'hinario' | 'infantil' | 'inadequada';
    tags: string[];
    toms: string[];
    hinarioNum?: string;
    lyrics: string;
    defaultTomKey: string;
    defaultQualifierCount: number;
  }
>();
for (const s of songs) {
  const existing = bySlug.get(s.slug);
  const tomKey = tomKeyOf(s);
  if (existing) {
    existing.toms.push(s.tom);
    for (const t of s.song.metadata.tags) {
      if (!existing.tags.includes(t)) existing.tags.push(t);
    }
    if (s.qualifiers.length < existing.defaultQualifierCount) {
      existing.defaultTomKey = tomKey;
      existing.defaultQualifierCount = s.qualifiers.length;
    }
  } else {
    bySlug.set(s.slug, {
      slug: s.slug,
      title: s.song.metadata.title,
      artist: s.song.metadata.artist,
      section: s.song.metadata.section,
      tags: [...s.song.metadata.tags],
      toms: [s.tom],
      hinarioNum: s.song.metadata.hinarioNum,
      lyrics: extractSearchableLyrics(s.song.raw),
      defaultTomKey: tomKey,
      defaultQualifierCount: s.qualifiers.length,
    });
  }
}
const entries = Array.from(bySlug.values()).map(
  ({ defaultQualifierCount: _unused, ...rest }) => rest,
);
---

<BaseLayout title="Músicas">
  <h1 class="text-2xl font-bold mb-4">Músicas</h1>
  <MusicasList client:load entries={entries} base={base} />
</BaseLayout>
