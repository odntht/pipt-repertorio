# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.pro]
# ChordPro: preservar espaços em branco — importantes pro alinhamento cifra/letra
trim_trailing_whitespace = false
